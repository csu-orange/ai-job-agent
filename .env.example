PORT=3000

# Optional. Supported values: local, openai, nvidia.
# When omitted, the app prefers OpenAI if OPENAI_API_KEY exists, then NVIDIA if
# NVIDIA_API_KEY exists, and otherwise uses the built-in local analysis engine.
AI_PROVIDER=local

# Optional OpenAI provider.
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4.1-mini

# Optional NVIDIA NIM provider.
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_TIMEOUT_MS=25000
NVIDIA_MAX_TOKENS=2048
